VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_BYPASS_AUTH=false

# Single backend base model:
# - Local Vite dev: leave VITE_API_BASE_URL empty and proxy /api/v1/casper to VITE_API_PROXY_TARGET.
# - Static dist hosting: set VITE_API_BASE_URL to the backend base URL because Vite proxy is not available.

# For static dist hosting (no Vite proxy), set this explicitly, e.g.:
# VITE_API_BASE_URL=http://localhost:5000
